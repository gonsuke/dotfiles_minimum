	name = Takashi Matsuno
	signingkey = 87BBE842988924B2

[includeIf "gitdir:~/Documents/projects/zettify/"]
    path = ~/.gitconfig-zettify

[alias]
	co = checkout
	ci = commit
	st = status
	br = branch
	rb = rebase
	pl = pull
	ps = push
	l = log --oneline
	lo = log
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
	delete-merged = "!f () { git checkout $1; git branch --merged|egrep -v '\\*|develop|master'|xargs git branch -d; git fetch --prune; }; f"

#[url "git@github.com:"]
