[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[commit]
	template = ~/.gitcommit_template
	gpgsign = true

[pager]
	branch = cat
